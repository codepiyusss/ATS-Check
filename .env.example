# Copy this file to .env and fill in your own values.
# Never commit your real .env file to version control.

# Used by Flask for sessions and flash messages. Set this to a long,
# random string in production.
SECRET_KEY=change-this-to-a-random-secret-key

# Optional: if you have a Gemini API key, resume analysis will use it.
# If left blank, the app automatically falls back to a built-in
# rule-based analyzer so the project still works without any key.
GEMINI_API_KEY=
